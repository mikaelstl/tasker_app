{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "paths": {
      "@components/*":   [ "./src/app/components/*" ],
      "@base/*":         [ "./src/app/components/base/*" ],
